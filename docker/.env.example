# Taktflow Embedded Production — Docker environment variables
# Copy to .env and customize for your deployment.

# MQTT authentication (must match gateway/mosquitto/passwd)
MQTT_USER=taktflow
MQTT_PASSWORD=taktflow-dev

# Fault injection API key (empty = dev mode, no auth)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
FAULT_API_KEY=

# SIL time scale (1.0 = real-time, <1 = slower for debugging)
SIL_TIME_SCALE=1

# AWS IoT Core (production Pi deployment only)
AWS_IOT_ENDPOINT=
DEVICE_ID=taktflow-dev-001
